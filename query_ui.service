[Unit]
Description=Query UI - Investment Research Knowledge Base
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/mickey/.openclaw/mihua/tools/query_ui
ExecStart=/usr/bin/python3.10 -m uvicorn app:app --host 0.0.0.0 --port 8899
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
